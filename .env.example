# Copy to .env and fill in (real .env is git-ignored).
EGYM_USERNAME=you@example.com
EGYM_PASSWORD=your-egym-password

# Email notifications (Gmail: use an App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password
NOTIFY_EMAIL=you@gmail.com
